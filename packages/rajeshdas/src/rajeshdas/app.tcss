/*
 * Custom styles for PortfolioApp
 */

TabbedContent {
    height: 1fr;
}

TabPane {
    padding: 1 2;
}

Footer {
    background: $background;
}

/* Markdown styling overrides */
Markdown MarkdownH1 {
    text-align: left;
    margin: 0 0 1 0;
}

Markdown MarkdownH2 {
    text-align: left;
    margin: 1 0;
}
